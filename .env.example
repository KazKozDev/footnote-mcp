# footnote-mcp environment template.
# Copy this file to `.env` for local use, or paste selected variables into your
# MCP client config under the server's `env` field.
#
# All keys below are optional. The server starts without API keys and falls back
# to scraped Bing + DuckDuckGo search, browser fallback, and offline verification.

# Optional search providers.
# `web_search` tries keyed providers in this order when keys are present:
# Tavily -> Brave -> Google -> scraped Bing + DuckDuckGo.
TAVILY_API_KEY=
BRAVE_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Optional semantic reranking via local Ollama embeddings.
# Used when a tool request enables semantic search/reranking.
FOOTNOTE_EMBED_MODEL=bge-m3

# Optional local NLI model for `evidence_entailment` with backend="local_nli".
# Requires installing the extra dependencies from `requirements-nli.txt`.
FOOTNOTE_NLI_MODEL=

# Browser fallback for JavaScript-heavy or blocked pages.
# Enabled by default; set to 0 to disable the Chromium fallback tier.
FOOTNOTE_BROWSER_FALLBACK=1

# Optional proxy support for fetch/browser escalation.
# Use comma-separated proxy URLs; leave empty for direct connections.
FOOTNOTE_PROXIES=

# Optional hosted scrape API fallback.
# Set FOOTNOTE_SCRAPE_API to `firecrawl` or `scrapingbee`, then provide the
# matching provider key below.
FOOTNOTE_SCRAPE_API=
FIRECRAWL_API_KEY=
SCRAPINGBEE_API_KEY=

# Fetch politeness and anti-blocking controls.
# Defaults are conservative enough for normal use; tune only when needed.
FOOTNOTE_DOMAIN_RPS=3
FOOTNOTE_DOMAIN_BURST=5
FOOTNOTE_BREAKER_THRESHOLD=5
FOOTNOTE_BREAKER_COOLDOWN=120
FOOTNOTE_NEGCACHE_TTL=300
FOOTNOTE_THIN_CONTENT_CHARS=200

# Persistent source cache.
# Default: ~/.footnote-mcp/source_cache/
FOOTNOTE_SOURCE_CACHE=
